---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'GoldWhite Consulting | STEM Startup Advisory',
  description = 'Specialist STEM advisory for startups and technology companies. London.',
} = Astro.props;

const path = Astro.url.pathname;
const nav = (href: string) => path === href || path.startsWith(href + '/') ? 'nav-link nav-link--active' : 'nav-link';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>

    <!-- ═══ NAVIGATION ═══ -->
    <nav
      id="main-nav"
      style="position:fixed;top:0;left:0;right:0;z-index:900;padding:0 60px;height:72px;display:flex;align-items:center;justify-content:space-between;background:rgba(11,17,32,0.95);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);transition:all .4s ease;"
    >
      <!-- Logo -->
      <a href="/" style="font-family:'Playfair Display',serif;font-size:22px;font-weight:600;color:#fff;letter-spacing:1px;display:flex;align-items:center;gap:10px;text-decoration:none;">
        <span style="width:28px;height:28px;border:2px solid #C9A84C;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:14px;color:#C9A84C;font-weight:700;flex-shrink:0;">G</span>
        GoldWhite
      </a>

      <!-- Desktop links -->
      <div style="display:flex;align-items:center;gap:36px;" id="nav-links">
        <a href="/services"     class={nav('/services')}>Services</a>
        <a href="/sectors"      class={nav('/sectors')}>Sectors</a>
        <a href="/case-studies" class={nav('/case-studies')}>Case Studies</a>
        <a href="/insights"     class={nav('/insights')}>Insights</a>
        <a href="/team"         class={nav('/team')}>Team</a>
        <a href="/contact"      class={nav('/contact')}>Contact</a>
        <a
          href="/contact"
          style="background:#C9A84C;color:#0F1A2E;padding:10px 24px;border-radius:6px;font-weight:600;font-size:13px;letter-spacing:.5px;text-decoration:none;transition:all .3s;white-space:nowrap;"
          onmouseover="this.style.background='#E0C777';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.background='#C9A84C';this.style.transform='none'"
        >Book a Call</a>
      </div>

      <!-- Hamburger button (mobile only) -->
      <button id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="ham-bar"></span>
        <span class="ham-bar"></span>
        <span class="ham-bar"></span>
      </button>
    </nav>

    <!-- ═══ MOBILE MENU ═══ -->
    <div id="mobile-menu" role="navigation" aria-label="Mobile navigation">
      <div class="mob-links">
        <a href="/services"     class={"mob-nav-link " + nav('/services')}>Services</a>
        <a href="/sectors"      class={"mob-nav-link " + nav('/sectors')}>Sectors</a>
        <a href="/case-studies" class={"mob-nav-link " + nav('/case-studies')}>Case Studies</a>
        <a href="/insights"     class={"mob-nav-link " + nav('/insights')}>Insights</a>
        <a href="/team"         class={"mob-nav-link " + nav('/team')}>Team</a>
        <a href="/contact"      class={"mob-nav-link " + nav('/contact')}>Contact</a>
      </div>
      <div style="padding-top:20px;">
        <a
          href="/contact"
          style="display:flex;align-items:center;justify-content:center;gap:8px;background:#C9A84C;color:#0F1A2E;padding:16px 24px;border-radius:8px;text-decoration:none;font-weight:600;font-size:15px;letter-spacing:.3px;"
        >Book a Strategy Call →</a>
      </div>
    </div>

    <!-- Page content -->
    <slot />

    <!-- ═══ FOOTER ═══ -->
    <footer class="footer-outer" style="background:#0F1A2E;border-top:1px solid rgba(255,255,255,.06);padding:64px 60px 40px;">
      <div class="footer-grid" style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px;max-width:1200px;">

        <!-- Brand -->
        <div>
          <div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:600;color:#fff;margin-bottom:14px;">GoldWhite</div>
          <p style="font-size:14px;line-height:1.7;color:rgba(255,255,255,.4);max-width:280px;">Specialist STEM advisory for startups and technology companies. London.</p>
        </div>

        <!-- Services -->
        <div>
          <h4 style="font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:20px;">Services</h4>
          {[
            ['Fundraising',       '/services#fundraising'],
            ['Product Strategy',  '/services#product'],
            ['Go-to-Market',      '/services#gtm'],
            ['Operations',        '/services#operations'],
          ].map(([label, href]) => (
            <a href={href} style="display:block;font-size:14px;color:rgba(255,255,255,.4);text-decoration:none;margin-bottom:12px;min-height:44px;display:flex;align-items:center;transition:color .3s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.4)'">{label}</a>
          ))}
        </div>

        <!-- Company -->
        <div>
          <h4 style="font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:20px;">Company</h4>
          {[
            ['Team',         '/team'],
            ['Case Studies', '/case-studies'],
            ['Insights',     '/insights'],
            ['Contact',      '/contact'],
          ].map(([label, href]) => (
            <a href={href} style="display:block;font-size:14px;color:rgba(255,255,255,.4);text-decoration:none;margin-bottom:12px;min-height:44px;display:flex;align-items:center;transition:color .3s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.4)'">{label}</a>
          ))}
        </div>

        <!-- Connect -->
        <div>
          <h4 style="font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:20px;">Connect</h4>
          {[
            ['LinkedIn',              'https://linkedin.com'],
            ['info@goldwhite.co.uk',  'mailto:info@goldwhite.co.uk'],
            ['Book a Call',           '/contact'],
          ].map(([label, href]) => (
            <a href={href} style="display:block;font-size:14px;color:rgba(255,255,255,.4);text-decoration:none;margin-bottom:12px;min-height:44px;display:flex;align-items:center;transition:color .3s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.4)'">{label}</a>
          ))}
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="footer-bottom" style="border-top:1px solid rgba(255,255,255,.06);padding-top:32px;display:flex;justify-content:space-between;align-items:center;max-width:1200px;">
        <p style="font-size:13px;color:rgba(255,255,255,.3);">© 2026 GoldWhite Ltd. All rights reserved.</p>
        <div class="footer-bottom-links">
          <a href="/privacy" style="font-size:13px;color:rgba(255,255,255,.3);text-decoration:none;margin-left:24px;transition:color .3s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.3)'">Privacy Policy</a>
          <a href="/terms"   style="font-size:13px;color:rgba(255,255,255,.3);text-decoration:none;margin-left:24px;transition:color .3s;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.3)'">Terms &amp; Conditions</a>
        </div>
      </div>
    </footer>

    <!-- ═══ SCROLL REVEAL ═══ -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>

  </body>
</html>

<!-- ═══ NAV + FOOTER RESPONSIVE STYLES ═══ -->
<style is:global>
  /* ── Hamburger button ── */
  #hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 4px;
    flex-direction: column;
    gap: 5px;
    align-items: center;
    justify-content: center;
  }
  .ham-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #C9A84C;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  #hamburger.open .ham-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  #hamburger.open .ham-bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  #hamburger.open .ham-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile menu ── */
  #mobile-menu {
    display: none;
    position: fixed;
    top: 72px;
    left: 0;
    right: 0;
    z-index: 899;
    background: rgba(9, 15, 28, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(201, 168, 76, 0.15);
    padding: 8px 20px 28px;
    max-height: calc(100vh - 72px);
    overflow-y: auto;
  }
  #mobile-menu.open { display: block; }

  .mob-nav-link {
    display: flex;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    min-height: 52px;
    transition: color 0.25s;
  }
  .mob-nav-link:hover { color: #fff; }
  .mob-nav-link.nav-link--active { color: #fff; }

  /* ── Mobile breakpoint ── */
  @media (max-width: 767px) {
    #main-nav  { padding: 0 20px !important; }
    #nav-links { display: none !important; }
    #hamburger { display: flex !important; }
  }

  /* ── Footer responsive ── */
  @media (max-width: 767px) {
    .footer-outer { padding: 48px 20px 32px !important; }
    .footer-grid  { grid-template-columns: 1fr !important; gap: 32px !important; }
    .footer-bottom {
      flex-direction: column !important;
      gap: 16px !important;
      align-items: flex-start !important;
    }
    .footer-bottom-links a { margin-left: 0 !important; margin-right: 20px; }
  }
</style>

<script is:inline>
(function () {
  var ham  = document.getElementById('hamburger');
  var menu = document.getElementById('mobile-menu');
  if (!ham || !menu) return;

  ham.addEventListener('click', function () {
    var open = menu.classList.toggle('open');
    ham.classList.toggle('open', open);
    ham.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  });

  menu.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', function () {
      menu.classList.remove('open');
      ham.classList.remove('open');
      ham.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
})();
</script>
