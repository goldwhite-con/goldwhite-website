---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  tag: string;
  headline: string;
  metrics: { value: string; label: string }[];
  challenge: string;
  whatWeDid: string;
  result: string;
  pullQuote: string;
}

const { title, description, tag, headline, metrics, challenge, whatWeDid, result, pullQuote } = Astro.props;
---

<BaseLayout title={title} description={description}>

  <style>
    @media (max-width: 640px) {
      .cs-hero    { padding: 140px 24px 72px !important; }
      .cs-body    { padding: 60px 24px 60px !important; }
      .cs-nav     { padding: 28px 24px !important; flex-direction: column !important; gap: 16px !important; align-items: flex-start !important; }
    }
    @media (max-width: 860px) {
      .cs-metrics { gap: 32px !important; }
      .cs-metric  { padding: 0 24px 0 0 !important; border-right: none !important; }
    }
  </style>

  <!-- ═══ HERO ═══ -->
  <section class="cs-hero pg-hero" style="padding:160px 60px 100px;background:#0F1A2E;position:relative;overflow:hidden;text-align:center;">

    <!-- Glow -->
    <div class="pulse-slow" style="position:absolute;top:-40%;right:-15%;width:700px;height:700px;background:radial-gradient(circle,rgba(201,168,76,.07) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
    <div class="hero-grid"></div>

    <div style="position:relative;z-index:2;max-width:820px;margin:0 auto;">

      <!-- Sector tag -->
      <div class="anim-1" style="display:inline-block;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#C9A84C;background:rgba(201,168,76,.12);padding:6px 16px;border-radius:4px;margin-bottom:28px;">{tag}</div>

      <!-- Headline -->
      <h1 class="anim-2" style="font-family:'Playfair Display',serif;font-size:clamp(28px,3.6vw,46px);font-weight:600;line-height:1.15;color:#fff;margin-bottom:64px;">{headline}</h1>

      <!-- Metrics row -->
      <div class="anim-3 cs-metrics" style="display:flex;justify-content:center;align-items:flex-start;flex-wrap:wrap;gap:0;">
        {metrics.map(({ value, label }, i) => (
          <div
            class="cs-metric"
            style={`padding:0 48px;${i < metrics.length - 1 ? 'border-right:1px solid rgba(255,255,255,.1);' : ''}`}
          >
            <div style="font-family:'Playfair Display',serif;font-size:clamp(24px,2.8vw,38px);font-weight:600;color:#C9A84C;line-height:1;margin-bottom:8px;">{value}</div>
            <div style="font-size:12px;color:rgba(255,255,255,.4);letter-spacing:.8px;font-weight:500;text-transform:uppercase;">{label}</div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══ BODY ═══ -->
  <section class="cs-body pg-section" style="padding:80px 60px 80px;background:#fff;">
    <div style="max-width:740px;margin:0 auto;">

      <!-- The Challenge -->
      <div class="reveal" style="margin-bottom:56px;">
        <div style="font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#C9A84C;margin-bottom:14px;">The Challenge</div>
        <p style="font-size:17px;line-height:1.9;color:#4A5568;">{challenge}</p>
      </div>

      <!-- What We Did -->
      <div class="reveal" style="margin-bottom:56px;">
        <div style="font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#C9A84C;margin-bottom:14px;">What We Did</div>
        <p style="font-size:17px;line-height:1.9;color:#4A5568;">{whatWeDid}</p>
      </div>

      <!-- Pull quote -->
      <div class="reveal" style="background:#F8F6F1;border-left:3px solid #C9A84C;border-radius:0 8px 8px 0;padding:28px 36px;margin-bottom:56px;">
        <p style="font-family:'Playfair Display',serif;font-size:19px;font-style:italic;line-height:1.65;color:#0F1A2E;">&ldquo;{pullQuote}&rdquo;</p>
      </div>

      <!-- The Result -->
      <div class="reveal">
        <div style="font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#C9A84C;margin-bottom:14px;">The Result</div>
        <p style="font-size:17px;line-height:1.9;color:#4A5568;">{result}</p>
      </div>

    </div>
  </section>

  <!-- ═══ BOTTOM NAV BAND ═══ -->
  <div class="cs-nav" style="background:#F8F6F1;border-top:1px solid #E2E0DB;padding:32px 60px;display:flex;justify-content:space-between;align-items:center;">
    <a
      href="/case-studies"
      style="display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:600;color:#0F1A2E;text-decoration:none;letter-spacing:.2px;transition:color .3s;"
      onmouseover="this.style.color='#C9A84C'"
      onmouseout="this.style.color='#0F1A2E'"
    >← Back to Case Studies</a>
    <a
      href="/contact"
      style="display:inline-flex;align-items:center;gap:8px;background:#C9A84C;color:#0F1A2E;padding:14px 28px;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;letter-spacing:.3px;transition:all .3s;"
      onmouseover="this.style.background='#E0C777';this.style.transform='translateY(-2px)'"
      onmouseout="this.style.background='#C9A84C';this.style.transform='none'"
    >Book a Strategy Call →</a>
  </div>

</BaseLayout>
