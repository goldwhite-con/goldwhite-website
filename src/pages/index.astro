---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TrendingUp, FlaskConical, Rocket } from 'lucide-astro';

const services = [
  {
    icon: TrendingUp,
    title: 'Fundraising & Financial Strategy',
    body: '£12M+ raised across pre-seed to Series B. We bring institutional finance experience: from financial modelling and pitch materials to running investor processes and negotiating terms.',
    delay: 'reveal-delay-1',
  },
  {
    icon: FlaskConical,
    title: 'Scientific & Product Strategy',
    body: "From scientific rationale to regulatory clearance. We've launched CE-marked devices, achieved FDA clearance, developed AI-driven biomarkers, designed clinical trial strategies, and helped companies integrate AI, including agentic systems, into their products and operations.",
    delay: 'reveal-delay-2',
  },
  {
    icon: Rocket,
    title: 'Go-to-Market & Operations',
    body: 'A brilliant product means nothing without a path to market. We define positioning, plan launches, build operational processes, and manage stakeholders through to commercial success.',
    delay: 'reveal-delay-3',
  },
];

const differentiators = [
  {
    num: '01',
    title: 'Scientists Who Speak Business',
    body: 'Two-thirds of our team hold PhDs from world-leading universities. We combine deep technical fluency with the commercial and financial acumen to translate innovation into funded, market-ready products.',
    delay: 'reveal-delay-1',
  },
  {
    num: '02',
    title: 'Operators, Not Observers',
    body: "We've founded, funded, and exited our own ventures. Traded derivatives at Goldman Sachs. Led translational science at a leading global pharmaceutical company. Designed landmark buildings across three continents. We advise from experience, not theory.",
    delay: 'reveal-delay-2',
  },
  {
    num: '03',
    title: 'Embedded, Not Detached',
    body: 'We integrate with your team for as long as you need us. We attend your board meetings, join your investor calls, and work alongside your engineers. We succeed when you succeed.',
    delay: 'reveal-delay-3',
  },
  {
    num: '04',
    title: 'AI-Native, Not AI-Aware',
    body: 'We have built, launched, and regulated AI-driven products in clinical environments. From CE-marked oncology biomarkers to FDA-cleared imaging tools, we understand what it takes to get AI products through development, validation, and to market. We help our clients do the same. We also help companies design and implement agentic AI workflows into their products and operations.',
    delay: 'reveal-delay-1',
  },
];

const team = [
  {
    initials: 'MG',
    name: 'Marc Goldfinger, PhD',
    role: 'Life Sciences & Health-Tech Strategy',
    creds: [
      'Director, Translational Sciences — leading global pharmaceutical company',
      'PhD Clinical Neuroscience, Imperial College',
      'Published in Brain, Nature Communications',
      'US Patent: AI-driven biomarker detection',
    ],
    delay: 'reveal-delay-1',
  },
  {
    initials: 'DW',
    name: 'David Weiss, PhD',
    role: 'Fundraising & Commercial Strategy',
    creds: [
      'PhD Engineering, University of Cambridge',
      'Ex-Goldman Sachs, Equity Derivatives',
      '£12M+ raised for clients',
      'Co-founded & exited tech startup',
    ],
    delay: 'reveal-delay-2',
  },
  {
    initials: 'JW',
    name: 'Jonas Weiss',
    role: 'Product & Operations',
    creds: [
      'MA Architecture, Bartlett (UCL)',
      'Co-founded & exited tech startup',
      '€200M+ project experience',
      'Product, UX & project management',
    ],
    delay: 'reveal-delay-3',
  },
];

const proof = [
  { number: '£12M+', label: 'Raised for Clients' },
  { number: '2',     label: 'PhDs on the Team' },
  { number: '25+',   label: 'Publications' },
  { number: '6',     label: 'CE-Marked Products' },
  { number: 'FDA',   label: 'Clearance Achieved' },
  { number: '8',     label: 'AI/ML Products Launched' },
];
---

<BaseLayout
  title="GoldWhite Consulting — STEM Startup Advisory"
  description="Deep scientific expertise meets hands-on commercial experience. From fundraising to product launch, we work alongside your team to deliver results."
>

  <style>
    /* ── Hero ── */
    @media (max-width: 767px) {
      .home-hero { padding: 120px 20px 72px !important; }
    }

    /* ── Hero CTA buttons ── */
    @media (max-width: 767px) {
      .hero-cta { flex-direction: column !important; }
      .hero-cta a { width: 100% !important; justify-content: center !important; box-sizing: border-box !important; }
    }

    /* ── Proof bar ── */
    @media (max-width: 767px) {
      .proof-bar {
        padding: 32px 20px !important;
        display: grid !important;
        grid-template-columns: repeat(2, 1fr) !important;
        gap: 28px 16px !important;
        justify-items: center !important;
      }
    }

    /* ── Services ── */
    @media (max-width: 767px) {
      .home-services-section { padding: 72px 20px !important; }
      .home-services-grid { grid-template-columns: 1fr !important; }
    }

    /* ── Why GoldWhite ── */
    @media (max-width: 767px) {
      .home-why-section { padding: 72px 20px !important; }
      .home-why-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
      .home-ai-block { padding: 20px 20px 24px !important; }
    }

    /* ── Team ── */
    @media (max-width: 767px) {
      .home-team-section { padding: 72px 20px !important; }
      .home-team-grid { grid-template-columns: 1fr !important; }
      .team-card-photo { height: 220px !important; }
    }

    /* ── Featured case study ── */
    @media (max-width: 767px) {
      .home-cs-section { padding: 72px 20px !important; }
      .cs-featured-grid { grid-template-columns: 1fr !important; }
      .cs-stat-panel { padding: 40px 24px !important; }
      .cs-copy-panel { padding: 36px 24px !important; }
    }

    /* ── Bottom CTA ── */
    @media (max-width: 767px) {
      .home-cta-section { padding: 72px 20px !important; }
    }
  </style>

  <!-- ═══ HERO ═══ -->
  <section class="home-hero" style="min-height:100vh;padding:160px 60px 100px;background:#0F1A2E;position:relative;overflow:hidden;display:flex;align-items:center;">

    <!-- Glow orbs -->
    <div class="pulse-slow"  style="position:absolute;top:-50%;right:-20%;width:900px;height:900px;background:radial-gradient(circle,rgba(201,168,76,.08) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
    <div class="pulse-slow-r" style="position:absolute;bottom:-30%;left:-10%;width:600px;height:600px;background:radial-gradient(circle,rgba(201,168,76,.05) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>

    <!-- Subtle grid -->
    <div class="hero-grid"></div>

    <!-- Two-column content -->
    <div class="hero-split" style="position:relative;z-index:2;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;max-width:1240px;">

      <!-- Left: copy -->
      <div>
        <div class="anim-1" style="display:inline-flex;align-items:center;gap:10px;font-size:13px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#C9A84C;margin-bottom:32px;">
          <span style="width:40px;height:1.5px;background:#C9A84C;display:inline-block;"></span>
          STEM Advisory
          <span style="width:40px;height:1.5px;background:#C9A84C;display:inline-block;"></span>
        </div>

        <h1 class="anim-2" style="font-family:'Playfair Display',serif;font-size:clamp(38px,4.5vw,62px);font-weight:600;line-height:1.12;color:#fff;margin-bottom:28px;">
          Helping STEM startups <em style="font-style:italic;color:#C9A84C;">raise capital,</em> build products, and reach market.
        </h1>

        <p class="anim-3" style="font-size:18px;line-height:1.75;color:rgba(255,255,255,.6);margin-bottom:48px;">
          Deep scientific expertise meets hands-on commercial experience. We have a particular focus on healthtech, medtech, and diagnostics companies, with a track record of getting them funded, cleared, and to market.
        </p>

        <div class="anim-4 hero-cta" style="display:flex;gap:16px;flex-wrap:wrap;">
          <a
            href="/contact"
            style="display:inline-flex;align-items:center;gap:8px;background:#C9A84C;color:#0F1A2E;padding:16px 32px;border-radius:8px;text-decoration:none;font-weight:600;font-size:15px;letter-spacing:.3px;transition:all .3s;"
            onmouseover="this.style.background='#E0C777';this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 30px rgba(201,168,76,.25)'"
            onmouseout="this.style.background='#C9A84C';this.style.transform='none';this.style.boxShadow='none'"
          >Book a Strategy Call →</a>
          <a
            href="/case-studies"
            style="display:inline-flex;align-items:center;gap:8px;background:transparent;color:#fff;padding:16px 32px;border-radius:8px;text-decoration:none;font-weight:500;font-size:15px;border:1.5px solid rgba(255,255,255,.2);transition:all .3s;"
            onmouseover="this.style.borderColor='#C9A84C';this.style.color='#C9A84C'"
            onmouseout="this.style.borderColor='rgba(255,255,255,.2)';this.style.color='#fff'"
          >See Our Work</a>
        </div>
      </div>

      <!-- Right: abstract geometric visual -->
      <div class="hero-visual anim-2" style="position:relative;display:flex;align-items:center;justify-content:center;">

        <!-- SVG — layered hexagons, molecular nodes, connecting lines -->
        <svg viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg"
             style="width:100%;max-width:480px;display:block;overflow:visible;">
          <defs>
            <radialGradient id="gGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%"   stop-color="#C9A84C" stop-opacity="0.09"/>
              <stop offset="100%" stop-color="#C9A84C" stop-opacity="0"/>
            </radialGradient>
            <radialGradient id="gGlowW" cx="50%" cy="50%" r="50%">
              <stop offset="0%"   stop-color="#ffffff" stop-opacity="0.04"/>
              <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
            </radialGradient>
          </defs>

          <!-- Ambient centre glow -->
          <circle cx="240" cy="240" r="190" fill="url(#gGlow)"/>
          <circle cx="240" cy="240" r="120" fill="url(#gGlowW)"/>

          <!-- Outermost faint circle ring -->
          <circle cx="240" cy="240" r="228"
                  stroke="white" stroke-width="0.6" stroke-opacity="0.05" fill="none"/>

          <!-- ── Large outer hexagon (pointy-top, R=198) — rotates CW slowly ── -->
          <g class="geo-spin-cw" style="transform-origin:240px 240px;">
            <polygon
              points="240,42 411,141 411,339 240,438 69,339 69,141"
              stroke="#C9A84C" stroke-width="1.1" stroke-opacity="0.22" fill="none"
              stroke-dasharray="6 3"/>
            <!-- Vertex glow dots -->
            <circle cx="240" cy="42"  r="4"   fill="#C9A84C" fill-opacity="0.8"/>
            <circle cx="411" cy="141" r="3"   fill="#C9A84C" fill-opacity="0.65"/>
            <circle cx="411" cy="339" r="3"   fill="#C9A84C" fill-opacity="0.65"/>
            <circle cx="240" cy="438" r="4"   fill="#C9A84C" fill-opacity="0.8"/>
            <circle cx="69"  cy="339" r="3"   fill="#C9A84C" fill-opacity="0.65"/>
            <circle cx="69"  cy="141" r="3"   fill="#C9A84C" fill-opacity="0.65"/>
          </g>

          <!-- ── Medium inner hexagon (flat-top, R=122) — rotates CCW slowly ── -->
          <g class="geo-spin-ccw" style="transform-origin:240px 240px;">
            <polygon
              points="362,240 301,346 179,346 118,240 179,134 301,134"
              stroke="white" stroke-width="0.9" stroke-opacity="0.12" fill="none"/>
            <!-- Midpoint accent dots -->
            <circle cx="362" cy="240" r="2.5" fill="white" fill-opacity="0.35"/>
            <circle cx="118" cy="240" r="2.5" fill="white" fill-opacity="0.35"/>
            <circle cx="301" cy="134" r="2"   fill="white" fill-opacity="0.25"/>
            <circle cx="179" cy="346" r="2"   fill="white" fill-opacity="0.25"/>
          </g>

          <!-- ── Sparse molecular spokes from centre ── -->
          <g stroke="#C9A84C" stroke-opacity="0.1" stroke-width="0.8">
            <line x1="240" y1="240" x2="179" y2="134"/>
            <line x1="240" y1="240" x2="301" y2="346"/>
            <line x1="240" y1="240" x2="362" y2="240"/>
          </g>

          <!-- ── Connecting lines: outer hex → small accents ── -->
          <g stroke="#C9A84C" stroke-opacity="0.14" stroke-width="0.8">
            <line x1="240" y1="42"  x2="348" y2="88"/>
            <line x1="411" y1="141" x2="422" y2="90"/>
            <line x1="411" y1="339" x2="436" y2="315"/>
            <line x1="69"  y1="339" x2="80"  y2="370"/>
          </g>

          <!-- ── Small hex accent 1 — upper right, gold ── -->
          <g class="float-b" style="transform-origin:384px 115px;">
            <polygon
              points="384,73 422,95 422,139 384,161 346,139 346,95"
              fill="#C9A84C" fill-opacity="0.08" stroke="#C9A84C" stroke-width="1" stroke-opacity="0.28"/>
          </g>

          <!-- ── Small hex accent 2 — lower left, gold ── -->
          <g class="float-d" style="transform-origin:108px 370px;">
            <polygon
              points="108,336 137,353 137,387 108,404 79,387 79,353"
              fill="#C9A84C" fill-opacity="0.06" stroke="#C9A84C" stroke-width="0.9" stroke-opacity="0.22"/>
          </g>

          <!-- ── Small hex accent 3 — right middle, white ── -->
          <g class="float-c" style="transform-origin:430px 330px;">
            <polygon
              points="430,306 450,318 450,342 430,354 410,342 410,318"
              fill="white" fill-opacity="0.04" stroke="white" stroke-width="0.7" stroke-opacity="0.16"/>
          </g>

          <!-- ── Tiny hex — top left corner ── -->
          <polygon
            points="86,164 100,172 100,188 86,196 72,188 72,172"
            fill="white" fill-opacity="0.03" stroke="white" stroke-width="0.6" stroke-opacity="0.11"/>

          <!-- ── Small circle accent — lower right ── -->
          <g class="float-a" style="transform-origin:390px 390px;">
            <circle cx="390" cy="390" r="22"
                    fill="white" fill-opacity="0.03" stroke="white" stroke-width="0.7" stroke-opacity="0.12"/>
            <circle cx="390" cy="390" r="4"
                    fill="#C9A84C" fill-opacity="0.45"/>
          </g>

          <!-- ── Centre focal point ── -->
          <circle cx="240" cy="240" r="10"  fill="#C9A84C" fill-opacity="0.1"/>
          <circle cx="240" cy="240" r="4.5" fill="#C9A84C" fill-opacity="0.55"/>
          <circle cx="240" cy="240" r="1.8" fill="#C9A84C" fill-opacity="1"/>
        </svg>

        <!-- ── Floating credential badges ── -->

        <!-- Cambridge -->
        <div class="float-a" style="position:absolute;top:6%;left:3%;background:rgba(15,26,46,0.75);border:1px solid rgba(201,168,76,0.32);border-radius:8px;padding:9px 14px;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;align-items:center;gap:8px;white-space:nowrap;">
          <span style="width:5px;height:5px;border-radius:50%;background:#C9A84C;flex-shrink:0;display:inline-block;"></span>
          <span style="font-size:12px;font-weight:600;color:rgba(255,255,255,.85);letter-spacing:.4px;">Healthtech</span>
        </div>

        <!-- Goldman Sachs -->
        <div class="float-b" style="position:absolute;top:14%;right:0%;background:rgba(15,26,46,0.75);border:1px solid rgba(201,168,76,0.28);border-radius:8px;padding:9px 14px;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;align-items:center;gap:8px;white-space:nowrap;">
          <span style="width:5px;height:5px;border-radius:50%;background:#C9A84C;flex-shrink:0;display:inline-block;"></span>
          <span style="font-size:12px;font-weight:600;color:rgba(255,255,255,.85);letter-spacing:.4px;">Medtech</span>
        </div>

        <!-- Imperial College -->
        <div class="float-c" style="position:absolute;top:44%;left:1%;background:rgba(15,26,46,0.75);border:1px solid rgba(201,168,76,0.28);border-radius:8px;padding:9px 14px;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;align-items:center;gap:8px;white-space:nowrap;">
          <span style="width:5px;height:5px;border-radius:50%;background:#C9A84C;flex-shrink:0;display:inline-block;"></span>
          <span style="font-size:12px;font-weight:600;color:rgba(255,255,255,.85);letter-spacing:.4px;">Diagnostics</span>
        </div>

        <!-- Nature · Brain -->
        <div class="float-d" style="position:absolute;bottom:20%;right:1%;background:rgba(15,26,46,0.75);border:1px solid rgba(201,168,76,0.25);border-radius:8px;padding:9px 14px;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;align-items:center;gap:8px;white-space:nowrap;">
          <span style="width:5px;height:5px;border-radius:50%;background:#C9A84C;flex-shrink:0;display:inline-block;"></span>
          <span style="font-size:12px;font-weight:600;color:rgba(255,255,255,.85);letter-spacing:.4px;">Life Sciences</span>
        </div>

        <!-- FDA Cleared -->
        <div class="float-e" style="position:absolute;bottom:6%;left:22%;background:rgba(15,26,46,0.75);border:1px solid rgba(201,168,76,0.25);border-radius:8px;padding:9px 14px;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;align-items:center;gap:8px;white-space:nowrap;">
          <span style="width:5px;height:5px;border-radius:50%;background:#C9A84C;flex-shrink:0;display:inline-block;"></span>
          <span style="font-size:12px;font-weight:600;color:rgba(255,255,255,.85);letter-spacing:.4px;">Deep Tech</span>
        </div>

      </div><!-- /hero-visual -->

    </div><!-- /hero-split -->
  </section>

  <!-- ═══ PROOF BAR ═══ -->
  <div class="proof-bar" style="background:#182640;border-top:1px solid rgba(201,168,76,.15);border-bottom:1px solid rgba(201,168,76,.15);padding:40px 60px;display:flex;justify-content:center;gap:60px;flex-wrap:wrap;">
    {proof.map(({ number, label }) => (
      <div style="text-align:center;display:flex;flex-direction:column;align-items:center;gap:6px;">
        <span style="font-family:'Playfair Display',serif;font-size:32px;font-weight:600;color:#C9A84C;">{number}</span>
        <span style="font-size:13px;color:rgba(255,255,255,.5);letter-spacing:.5px;font-weight:500;">{label}</span>
      </div>
    ))}
  </div>

  <!-- ═══ SERVICES ═══ -->
  <section class="home-services-section" style="padding:120px 60px;background:#F8F6F1;">
    <div class="reveal" style="max-width:680px;margin-bottom:72px;">
      <div style="font-size:12px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#C9A84C;margin-bottom:16px;">What We Do</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(32px,3.5vw,46px);font-weight:600;line-height:1.2;color:#0F1A2E;margin-bottom:20px;">From first hypothesis to funded product.</h2>
      <p style="font-size:18px;line-height:1.7;color:#4A5568;">Every STEM startup faces a complex web of scientific, commercial, and financial challenges. We have particular depth in healthtech, medtech, and diagnostics. We bring together expertise that most firms cannot offer under one roof.</p>
    </div>

    <div class="home-services-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;max-width:1200px;">
      {services.map(({ icon: Icon, title, body, delay }) => (
        <div
          class={`service-card reveal ${delay}`}
          style="background:#fff;border:1px solid #E2E0DB;border-radius:12px;padding:44px 36px;transition:all .4s ease;position:relative;overflow:hidden;"
          onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 60px rgba(0,0,0,.08)';this.style.borderColor='transparent'"
          onmouseout="this.style.transform='none';this.style.boxShadow='none';this.style.borderColor='#E2E0DB'"
        >
          <div style="width:52px;height:52px;background:rgba(201,168,76,.15);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;">
            <Icon color="#C9A84C" size={32} strokeWidth={1.5} />
          </div>
          <h3 style="font-family:'Playfair Display',serif;font-size:22px;font-weight:600;margin-bottom:14px;color:#0F1A2E;">{title}</h3>
          <p style="font-size:15px;line-height:1.7;color:#4A5568;margin-bottom:24px;">{body}</p>
          <a
            href="/services"
            style="display:inline-flex;align-items:center;gap:6px;font-size:14px;font-weight:600;color:#C9A84C;text-decoration:none;letter-spacing:.3px;transition:gap .3s;"
            onmouseover="this.style.gap='12px'" onmouseout="this.style.gap='6px'"
          >Learn more →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ WHY GOLDWHITE ═══ -->
  <section class="home-why-section" style="padding:120px 60px;background:#0F1A2E;">
    <div class="reveal" style="max-width:680px;margin-bottom:72px;">
      <div style="font-size:12px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#C9A84C;margin-bottom:16px;">Why GoldWhite</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(32px,3.5vw,46px);font-weight:600;line-height:1.2;color:#fff;margin-bottom:20px;">We are not a typical consultancy.</h2>
      <p style="font-size:18px;line-height:1.7;color:rgba(255,255,255,.5);">Most consultancies send junior analysts with a playbook. We are three directors with PhDs, patents, and publications who do the work ourselves.</p>
    </div>

    <div class="home-why-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:48px;max-width:1200px;">
      {differentiators.slice(0, 3).map(({ num, title, body, delay }) => (
        <div class={`reveal ${delay}`}>
          <div style="font-family:'Playfair Display',serif;font-size:64px;font-weight:600;color:rgba(201,168,76,.38);line-height:1;margin-bottom:16px;">{num}</div>
          <h3 style="font-family:'Playfair Display',serif;font-size:22px;font-weight:600;margin-bottom:14px;color:#fff;">{title}</h3>
          <p style="font-size:15px;line-height:1.75;color:rgba(255,255,255,.55);">{body}</p>
        </div>
      ))}
    </div>

    <div class="reveal reveal-delay-1 home-ai-block" style="max-width:1200px;margin-top:36px;border-left:4px solid #C9A84C;background:#1C2A45;border-radius:0 8px 8px 0;padding:8px 48px 28px;">
      <div style="font-family:'Playfair Display',serif;font-size:64px;font-weight:600;color:rgba(201,168,76,.38);line-height:1;margin-bottom:16px;">{differentiators[3].num}</div>
      <h3 style="font-family:'Playfair Display',serif;font-size:25px;font-weight:600;margin-bottom:14px;color:#fff;">{differentiators[3].title}</h3>
      <p style="font-size:15px;line-height:1.75;color:rgba(255,255,255,.55);max-width:820px;">{differentiators[3].body}</p>
    </div>
  </section>

  <!-- ═══ TEAM ═══ -->
  <section class="home-team-section" style="padding:120px 60px;background:#fff;">
    <div class="reveal" style="max-width:680px;margin:0 auto 72px;text-align:center;">
      <div style="font-size:12px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#C9A84C;margin-bottom:16px;">Our Team</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(32px,3.5vw,46px);font-weight:600;line-height:1.2;color:#0F1A2E;margin-bottom:20px;">Three directors. Three disciplines.</h2>
      <p style="font-size:18px;line-height:1.7;color:#4A5568;">Each of us brings a distinct expertise. Together, we cover the full spectrum of what STEM startups need to succeed.</p>
    </div>

    <div class="home-team-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:36px;max-width:1200px;margin:0 auto;">
      {team.map(({ initials, name, role, creds, delay }) => (
        <div
          class={`reveal ${delay}`}
          style="background:#fff;border-radius:12px;overflow:hidden;border:1px solid #E2E0DB;transition:all .4s ease;"
          onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 60px rgba(0,0,0,.08)'"
          onmouseout="this.style.transform='none';this.style.boxShadow='none'"
        >
          <div class="team-card-photo" style="width:100%;height:320px;background:#213352;display:flex;align-items:center;justify-content:center;position:relative;">
            <div style="width:80px;height:80px;border-radius:50%;border:2px solid rgba(201,168,76,.3);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:28px;color:#C9A84C;">{initials}</div>
          </div>
          <div style="padding:32px;">
            <h3 style="font-family:'Playfair Display',serif;font-size:20px;font-weight:600;color:#0F1A2E;margin-bottom:4px;">{name}</h3>
            <div style="font-size:13px;font-weight:600;color:#C9A84C;letter-spacing:.5px;margin-bottom:16px;">{role}</div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              {creds.map(c => (
                <div style="font-size:13px;color:#4A5568;display:flex;align-items:flex-start;gap:8px;line-height:1.5;">
                  <span style="width:5px;height:5px;border-radius:50%;background:#C9A84C;margin-top:6px;flex-shrink:0;display:inline-block;"></span>
                  {c}
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FEATURED CASE STUDY ═══ -->
  <section class="home-cs-section" style="padding:120px 60px;background:#F8F6F1;">
    <div class="reveal" style="max-width:680px;margin:0 auto 72px;text-align:center;">
      <div style="font-size:12px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:#C9A84C;margin-bottom:16px;">Our Work</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(32px,3.5vw,46px);font-weight:600;line-height:1.2;color:#0F1A2E;">Real challenges. Measurable results.</h2>
    </div>

    <div class="reveal cs-featured-grid" style="max-width:900px;margin:0 auto;background:#fff;border-radius:16px;border:1px solid #E2E0DB;overflow:hidden;display:grid;grid-template-columns:1fr 1.2fr;">
      <!-- Stat panel -->
      <div class="cs-stat-panel" style="background:linear-gradient(135deg,#0F1A2E 0%,#213352 100%);padding:60px 40px;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;">
        <div style="font-family:'Playfair Display',serif;font-size:56px;font-weight:600;color:#C9A84C;line-height:1;margin-bottom:8px;">£3.2M</div>
        <div style="font-size:14px;color:rgba(255,255,255,.5);letter-spacing:.5px;margin-bottom:32px;">Series A Raised</div>
        <div style="font-family:'Playfair Display',serif;font-size:36px;font-weight:600;color:#C9A84C;line-height:1;margin-bottom:8px;">4</div>
        <div style="font-size:14px;color:rgba(255,255,255,.5);letter-spacing:.5px;">Months to Close</div>
      </div>
      <!-- Copy panel -->
      <div class="cs-copy-panel" style="padding:48px 44px;">
        <span style="display:inline-block;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#C9A84C;background:rgba(201,168,76,.15);padding:6px 14px;border-radius:4px;margin-bottom:20px;">Health-Tech · Fundraising · Diagnostics</span>
        <h3 style="font-family:'Playfair Display',serif;font-size:24px;font-weight:600;line-height:1.3;color:#0F1A2E;margin-bottom:16px;">How we helped a pre-revenue health-tech startup raise £3.2M in Series A funding.</h3>
        <p style="font-size:15px;line-height:1.7;color:#4A5568;margin-bottom:28px;">A pre-revenue startup developing a non-invasive diagnostic device had a strong scientific foundation but lacked the commercial narrative and investor network to raise institutional capital. We rebuilt their pitch from the ground up, led investor meetings, and closed the round in four months.</p>
        <a
          href="/case-studies"
          style="display:inline-flex;align-items:center;gap:8px;background:#C9A84C;color:#0F1A2E;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;letter-spacing:.3px;transition:all .3s;"
          onmouseover="this.style.background='#E0C777';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.background='#C9A84C';this.style.transform='none'"
        >Read the Full Story →</a>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="home-cta-section" style="padding:120px 60px;background:#0F1A2E;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(201,168,76,.08) 0%,transparent 70%);pointer-events:none;"></div>
    <div class="reveal" style="position:relative;z-index:2;max-width:600px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(36px,4vw,50px);font-weight:600;color:#fff;margin-bottom:20px;">Ready to talk?</h2>
      <p style="font-size:17px;line-height:1.7;color:rgba(255,255,255,.5);margin-bottom:40px;">Every engagement starts with a conversation. Book a 30-minute strategy call with one of our directors. No pitch, no obligation. Just an honest assessment of how we can help.</p>
      <a
        href="/contact"
        style="display:inline-flex;align-items:center;gap:8px;background:#C9A84C;color:#0F1A2E;padding:18px 40px;border-radius:8px;text-decoration:none;font-weight:600;font-size:16px;letter-spacing:.3px;transition:all .3s;"
        onmouseover="this.style.background='#E0C777';this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 30px rgba(201,168,76,.3)'"
        onmouseout="this.style.background='#C9A84C';this.style.transform='none';this.style.boxShadow='none'"
      >Book a Strategy Call →</a>
    </div>
  </section>

</BaseLayout>
